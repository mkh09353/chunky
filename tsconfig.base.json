{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node", "bun"],
    "paths": {
      "@chunky/protocol": ["./packages/protocol/src/index.ts"],
      "@chunky/protocol/mock": ["./packages/protocol/src/mock.ts"],
      "@chunky/protocol/relay": ["./packages/protocol/src/relay.ts"],
      "@chunky/protocol/relay-crypto": ["./packages/protocol/src/relay-crypto.ts"],
      "@chunky/protocol/relay-client": ["./packages/protocol/src/relay-client.ts"]
    }
  }
}
