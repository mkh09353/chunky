{
  "name": "chunky-cli",
  "version": "0.3.8",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "workspaces": ["packages/*"],
  "bin": {
    "chunky": "./chunky.ts"
  },
  "scripts": {
    "server": "CHUNKY_AUTH=\"${CHUNKY_AUTH:-$HOME/.chunky/state/auth.json}\" bun run scripts/dev-server.ts",
    "tui": "CHUNKY_PORT=\"${CHUNKY_PORT:-4620}\" bun run packages/tui/src/index.tsx",
    "app": "bun run --cwd packages/app start",
    "app:dev": "CHUNKY_PORT=\"${CHUNKY_PORT:-4620}\" bun run --cwd packages/app dev",
    "app:hmr": "CHUNKY_PORT=\"${CHUNKY_PORT:-4620}\" bun run --cwd packages/app dev",
    "chunky": "bun run chunky.ts",
    "pair": "bun run packages/server/src/relay/pair.ts",
    "install:cli": "bash scripts/install.sh",
    "typecheck": "tsc -b && bun run --cwd packages/tui typecheck && bun run --cwd packages/app typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^24.0.0",
    "typescript": "^7.0.2"
  }
}
