{
  "name": "@chunky/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Electrobun desktop UI for Chunky — Astryx AppShell + chat",
  "scripts": {
    "dev": "concurrently -k \"vite --port 5173 --strictPort\" \"electrobun dev\"",
    "dev:vite": "vite --port 5173 --strictPort",
    "dev:electrobun": "electrobun dev",
    "start": "vite build && electrobun dev",
    "build": "vite build && electrobun build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.4",
    "@astryxdesign/theme-neutral": "^0.1.4",
    "@chunky/protocol": "workspace:*",
    "@heroicons/react": "^2.2.0",
    "@stylexjs/stylex": "^0.18.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^5.3.0",
    "electrobun": "^1.18.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
