{
  "name": "chunky-cli",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "bin": {
    "chunky": "./chunky.ts"
  },
  "scripts": {
    "server": "CHUNKY_AUTH=\"${CHUNKY_AUTH:-$HOME/.chunky/state/auth.json}\" bun run packages/server/src/index.ts",
    "tui": "bun run packages/tui/src/index.tsx",
    "chunky": "bun run chunky.ts",
    "install:cli": "bash scripts/install.sh",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.10.0",
    "typescript": "^7.0.2"
  }
}
